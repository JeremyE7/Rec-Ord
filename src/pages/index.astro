---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackgroundGlow from "../components/BackgroundGlow.astro";
---

<BaseLayout>
  <BackgroundGlow />

  <main
    class="relative z-10 min-h-[100dvh] h-[100dvh] flex flex-col items-stretch justify-center"
    style="padding-top: max(env(safe-area-inset-top), 5rem); padding-bottom: max(env(safe-area-inset-bottom), 3.5rem); padding-left: max(env(safe-area-inset-left), 1.5rem); padding-right: max(env(safe-area-inset-right), 2rem);"
  >
    <div id="app" class="w-full h-full flex flex-col"></div>
  </main>

  {/* Swipe-progress indicator. Fixed to the bottom of the viewport so
   *  it stays put regardless of where the focus card is. The gesture
   *  handler updates its `--swipe-progress` custom property during a
   *  vertical drag. Pure visual; `aria-hidden` and `pointer-events: none`. */}
  <div id="swipe-progress" class="swipe-progress" aria-hidden="true"></div>

  {/* Swipe-right hint. Fixed to the left edge of the viewport. When the
   *  user starts swiping right (which opens the new-record form), the
   *  gesture handler updates its `--swipe-hint-x` and `--swipe-hint-opacity`
   *  custom properties to slide the label in from the left, giving
   *  immediate visual feedback that the gesture is being recognized. */}
  <div id="swipe-hint-right" class="swipe-hint swipe-hint--right" aria-hidden="true">
    <span class="swipe-hint__arrow">→</span>
    <span class="swipe-hint__label">NEW RECORD</span>
  </div>
</BaseLayout>

<script>
  import "../scripts/app";
</script>
