---
// BackgroundGlow — two fixed, blurred yellow orbs that sit behind everything
// to add subtle atmospheric warmth. Decorative only.
---

<div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
  <div
    class="absolute top-1/4 -left-20 w-96 h-96 rounded-full bg-glow-a blur-[120px]"
  >
  </div>
  <div
    class="absolute bottom-1/4 -right-20 w-96 h-96 rounded-full bg-glow-b blur-[120px]"
  >
  </div>
</div>
